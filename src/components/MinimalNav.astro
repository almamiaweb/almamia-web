---
import { route, type Locale, type RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import LanguageSwitch from './LanguageSwitch.astro';

interface Props {
  lang: Locale;
  pageKey: RouteKey;
  /** true = transparente sobre el hero (home); false = sólida (resto del sitio). */
  overlay?: boolean;
}
const { lang, pageKey, overlay = true } = Astro.props;
const t = useTranslations(lang);

const links: { key: RouteKey; label: string }[] = [
  { key: 'home', label: t('nav.home') },
  { key: 'services', label: t('nav.services') },
  { key: 'menus', label: t('nav.menus') },
  { key: 'pastEvents', label: t('nav.events') },
  { key: 'about', label: t('nav.about') },
  { key: 'testimonials', label: t('nav.testimonials') },
  { key: 'faq', label: t('nav.faq') },
  { key: 'contact', label: t('nav.contact') },
];
// Zonas: "Chef privado en" + ciudades. Las que tienen página propia van con enlace;
// Menorca y Formentera (cobertura, sin página dedicada) van como texto.
const zones: { name: string; key?: RouteKey }[] = [
  { name: 'Ibiza', key: 'zoneIbiza' },
  { name: 'Mallorca', key: 'zoneMallorca' },
  { name: 'Menorca' },
  { name: 'Formentera' },
  { name: 'Barcelona', key: 'zoneBarcelona' },
];
const home = route('home', lang);
---

<div class:list={['mnav', { 'mnav--solid': !overlay }]}>
  <a href={home} class="mnav__brand" aria-label="Alma Mía"><span class="mnav__mark" aria-hidden="true"></span>Alma&nbsp;Mía</a>
  <div class="mnav__right">
    <LanguageSwitch lang={lang} pageKey={pageKey} class="!text-current" />
    <button type="button" id="mnav-burger" class="burger" aria-label={t('nav.menu')} aria-controls="fsmenu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</div>

<nav id="fsmenu" class="fsmenu" aria-label={t('nav.menu')} aria-hidden="true">
  <button type="button" id="fsmenu-close" class="fsmenu__close" aria-label={t('nav.close')}>
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
      <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
    </svg>
  </button>
  <div class="container-alma">
    <ul class="flex flex-col gap-1">
      {links.map((l) => (
        <li><a href={route(l.key, lang)}>{l.label}</a></li>
      ))}
    </ul>
    <div class="mt-10">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-[color:var(--color-crema)]/55">Chef privado en</p>
      <div class="mt-2 flex flex-wrap gap-x-5 gap-y-1.5 text-base text-[color:var(--color-crema)]/85">
        {zones.map((z) =>
          z.key ? (
            <a href={route(z.key, lang)} class="hover:text-[color:var(--color-ocre)]">{z.name}</a>
          ) : (
            <span>{z.name}</span>
          )
        )}
      </div>
    </div>
  </div>
</nav>

<script>
  function initMinimalNav() {
    const burger = document.getElementById('mnav-burger');
    const menu = document.getElementById('fsmenu');
    const closeBtn = document.getElementById('fsmenu-close');
    const nav = document.querySelector('.mnav');
    if (!burger || !menu) return;

    const main = document.getElementById('contenido');
    const footer = document.querySelector('footer');
    const setMenu = (open: boolean) => {
      menu.classList.toggle('is-open', open);
      menu.setAttribute('aria-hidden', String(!open));
      burger.classList.toggle('is-active', open);
      burger.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
      // Inertiza el fondo para lectores de pantalla/teclado mientras el menú está abierto
      [main, footer].forEach((el) => {
        if (!el) return;
        if (open) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      });
      // Gestión de foco
      if (open) (menu.querySelector('a') as HTMLElement | null)?.focus();
      else burger.focus();
    };

    burger.addEventListener('click', () => setMenu(!menu.classList.contains('is-open')));
    closeBtn?.addEventListener('click', () => setMenu(false));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));

    if (nav) nav.classList.toggle('mnav--scrolled', window.scrollY > window.innerHeight * 0.7);
  }

  // Nav sólida al hacer scroll (contraste garantizado), registrado una sola vez
  if (!(window as unknown as { __almaNav?: boolean }).__almaNav) {
    (window as unknown as { __almaNav?: boolean }).__almaNav = true;
    window.addEventListener(
      'scroll',
      () => {
        const nav = document.querySelector('.mnav');
        if (nav) nav.classList.toggle('mnav--scrolled', window.scrollY > window.innerHeight * 0.7);
      },
      { passive: true }
    );
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const menu = document.getElementById('fsmenu');
      if (!menu?.classList.contains('is-open')) return;
      // Reutiliza el botón cerrar → aplica foco e inert correctamente
      (document.getElementById('fsmenu-close') as HTMLElement | null)?.click();
    });
  }

  if (document.readyState !== 'loading') initMinimalNav();
  else document.addEventListener('DOMContentLoaded', initMinimalNav);
</script>
