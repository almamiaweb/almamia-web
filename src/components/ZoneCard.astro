---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  blurb: string;
  href: string;
  image: ImageMetadata;
  alt: string;
  cta: string;
}
const { title, blurb, href, image, alt, cta } = Astro.props;
---

<a href={href} class="group relative reveal block overflow-hidden rounded-[var(--radius-xl)] shadow-[var(--shadow-soft)]">
  <div class="aspect-[3/4] sm:aspect-[4/5]">
    <Image
      src={image}
      alt={alt}
      widths={[400, 600, 800]}
      sizes="(min-width: 768px) 32vw, 90vw"
      format="avif"
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-t from-[rgba(46,43,40,0.78)] via-[rgba(46,43,40,0.15)] to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 p-6 text-[color:var(--color-crema)]">
    <h3 class="text-2xl text-[color:var(--color-crema)]">{title}</h3>
    <p class="mt-1.5 text-sm text-[color:var(--color-crema)]/90">{blurb}</p>
    <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold">
      {cta}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</a>
