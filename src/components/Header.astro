---
import { route, type Locale, type RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import { whatsappLink } from '../lib/site';
import LanguageSwitch from './LanguageSwitch.astro';

interface Props {
  lang: Locale;
  pageKey: RouteKey;
}
const { lang, pageKey } = Astro.props;
const t = useTranslations(lang);

const servicesChildren: { key: RouteKey; label: string }[] = [
  { key: 'breakfasts', label: lang === 'es' ? 'Desayunos y brunch' : 'Breakfast & brunch' },
  { key: 'lunches', label: lang === 'es' ? 'Comidas y almuerzos' : 'Lunches' },
  { key: 'dinners', label: lang === 'es' ? 'Cenas privadas' : 'Private dinners' },
  { key: 'serviceEvents', label: lang === 'es' ? 'Eventos y celebraciones' : 'Events & celebrations' },
  { key: 'experience', label: lang === 'es' ? 'Experiencia de chef privado' : 'Private chef experience' },
];

const zonesChildren: { key: RouteKey; label: string }[] = [
  { key: 'zoneIbiza', label: 'Ibiza' },
  { key: 'zoneBarcelona', label: 'Barcelona' },
  { key: 'zoneMallorca', label: 'Mallorca' },
];

const waMsg =
  lang === 'es'
    ? 'Hola Jenn, me gustaría reservar una experiencia con Alma Mía.'
    : 'Hi Jenn, I would like to book an experience with Alma Mía.';
const homeHref = route('home', lang);
---

<header class="sticky top-0 z-50 border-b border-[color:var(--color-linea)] bg-[color:var(--color-crema)]/90 backdrop-blur-md">
  <div class="container-alma flex items-center justify-between gap-4 py-3.5">
    <!-- Marca -->
    <a href={homeHref} class="flex items-center gap-2.5 shrink-0" aria-label="Alma Mía — inicio">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-[color:var(--color-oliva)] text-[color:var(--color-crema)]" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="10" r="5.2" stroke="currentColor" stroke-width="1.6" />
          <line x1="6.5" y1="18" x2="17.5" y2="18" stroke="#C9A24E" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </span>
      <span class="text-xl leading-none font-serif">Alma&nbsp;Mía</span>
    </a>

    <!-- Navegación de escritorio -->
    <nav class="hidden lg:block" aria-label={t('nav.menu')}>
      <ul class="flex items-center gap-1">
        <li class="nav-has-sub relative">
          <a href={route('services', lang)} class="nav-link" aria-haspopup="true">{t('nav.services')}</a>
          <div class="nav-sub card-alma">
            <ul>
              {servicesChildren.map((c) => (
                <li><a href={route(c.key, lang)} class="nav-sublink">{c.label}</a></li>
              ))}
            </ul>
          </div>
        </li>
        <li class="nav-has-sub relative">
          <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">{t('nav.zones')}</button>
          <div class="nav-sub card-alma">
            <ul>
              {zonesChildren.map((c) => (
                <li><a href={route(c.key, lang)} class="nav-sublink">{c.label}</a></li>
              ))}
            </ul>
          </div>
        </li>
        <li><a href={route('menus', lang)} class="nav-link">{t('nav.menus')}</a></li>
        <li><a href={route('pastEvents', lang)} class="nav-link">{t('nav.events')}</a></li>
        <li><a href={route('about', lang)} class="nav-link">{t('nav.about')}</a></li>
        <li><a href={route('faq', lang)} class="nav-link">{t('nav.faq')}</a></li>
      </ul>
    </nav>

    <!-- Cluster derecho -->
    <div class="flex items-center gap-3">
      <LanguageSwitch lang={lang} pageKey={pageKey} class="hidden sm:inline-flex" />
      <a href={whatsappLink(waMsg)} class="btn btn-primary hidden md:inline-flex" data-cta="reserve">
        {t('cta.reserve')}
      </a>
      <!-- Botón menú móvil -->
      <button
        type="button"
        id="menu-toggle"
        class="lg:hidden grid h-10 w-10 place-items-center rounded-full border border-[color:var(--color-linea)]"
        aria-label={t('nav.menu')}
        aria-controls="mobile-nav"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Navegación móvil -->
  <nav id="mobile-nav" class="lg:hidden hidden border-t border-[color:var(--color-linea)] bg-[color:var(--color-crema)]" aria-label={t('nav.menu')}>
    <div class="container-alma py-5">
      <ul class="flex flex-col gap-1 text-lg font-serif">
        <li><a href={route('services', lang)} class="mobile-link">{t('nav.services')}</a></li>
        <li class="pl-4">
          <ul class="flex flex-col gap-0.5 text-base font-sans">
            {servicesChildren.map((c) => (
              <li><a href={route(c.key, lang)} class="mobile-sublink">{c.label}</a></li>
            ))}
          </ul>
        </li>
        <li class="pt-2 text-sm uppercase tracking-[0.2em] text-[color:var(--color-oliva-700)] font-sans">{t('nav.zones')}</li>
        <li class="pl-4">
          <ul class="flex flex-col gap-0.5 text-base font-sans">
            {zonesChildren.map((c) => (
              <li><a href={route(c.key, lang)} class="mobile-sublink">{c.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href={route('menus', lang)} class="mobile-link">{t('nav.menus')}</a></li>
        <li><a href={route('pastEvents', lang)} class="mobile-link">{t('nav.events')}</a></li>
        <li><a href={route('about', lang)} class="mobile-link">{t('nav.about')}</a></li>
        <li><a href={route('testimonials', lang)} class="mobile-link">{t('nav.testimonials')}</a></li>
        <li><a href={route('faq', lang)} class="mobile-link">{t('nav.faq')}</a></li>
        <li><a href={route('contact', lang)} class="mobile-link">{t('nav.contact')}</a></li>
      </ul>
      <div class="mt-5 flex items-center justify-between border-t border-[color:var(--color-linea)] pt-5 font-sans">
        <LanguageSwitch lang={lang} pageKey={pageKey} />
        <a href={whatsappLink(waMsg)} class="btn btn-primary">{t('cta.reserve')}</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-carbon);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: background-color 0.2s var(--ease-soft), color 0.2s var(--ease-soft);
  }
  .nav-link:hover { background-color: var(--color-arena); }

  .nav-sub {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 16rem;
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s var(--ease-soft), transform 0.2s var(--ease-soft),
      visibility 0.2s;
  }
  .nav-has-sub:hover .nav-sub,
  .nav-has-sub:focus-within .nav-sub {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-sublink {
    display: block;
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    color: var(--color-carbon);
  }
  .nav-sublink:hover { background-color: var(--color-arena); }

  .mobile-link {
    display: block;
    padding: 0.6rem 0;
    color: var(--color-carbon);
  }
  .mobile-sublink {
    display: block;
    padding: 0.4rem 0;
    color: var(--color-suave);
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
