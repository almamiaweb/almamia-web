---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AnswerBox from '../components/AnswerBox.astro';
import ContactForm from '../components/ContactForm.astro';
import CostaMap from '../components/CostaMap.astro';
import { route } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import { localBusinessSchema } from '../lib/schema';
import { CONTACT, SOCIAL, PENDIENTE, AREAS_SERVED } from '../lib/site';

const lang = 'es' as const;
const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.contact'), url: route('contact', lang) },
];
const business = localBusinessSchema(lang, '/og/og-default.jpg');
const phonePending = CONTACT.phone === PENDIENTE;
---

<BaseLayout
  lang={lang}
  pageKey="contact"
  title="Contacto · Reserva tu experiencia con Alma Mía"
  description="Contacta con Alma Mía para reservar tu experiencia de chef privada en Ibiza, Barcelona o Mallorca. Escríbeme por WhatsApp o desde el formulario y te preparo una propuesta a medida."
  jsonLd={[business]}
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">{t('nav.contact')}</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Hablemos de tu mesa</h1>
    <div class="mt-6"><AnswerBox>Cuéntame la ocasión, la fecha y la zona, y te preparo una propuesta a medida. Puedes escribirme por WhatsApp para una respuesta rápida o usar el formulario; te responderé personalmente.</AnswerBox></div>
  </section>

  <section class="container-alma pb-12">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.3fr]">
      <!-- Vías de contacto -->
      <div class="reveal">
        <h2 class="text-2xl">Contacto directo</h2>
        <p class="mt-3 text-[color:var(--color-suave)]">Sígueme en Instagram o llámame directamente.</p>
        <div class="mt-5 flex items-center gap-3">
          <a
            href={SOCIAL.instagram}
            target="_blank"
            rel="me noopener"
            aria-label={`Instagram ${SOCIAL.instagramHandle}`}
            class="grid h-12 w-12 place-items-center rounded-full border border-[color:var(--color-linea)] text-[color:var(--color-oliva-700)] transition-transform duration-300 hover:-translate-y-0.5 hover:bg-[color:var(--color-arena)]"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" />
              <circle cx="12" cy="12" r="4.2" />
              <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
            </svg>
          </a>
          {!phonePending && (
            <a
              href={`tel:${CONTACT.phone.replace(/\s/g, '')}`}
              aria-label={`Llamar al ${CONTACT.phone}`}
              data-cta="call"
              class="grid h-12 w-12 place-items-center rounded-full border border-[color:var(--color-linea)] text-[color:var(--color-oliva-700)] transition-transform duration-300 hover:-translate-y-0.5 hover:bg-[color:var(--color-arena)]"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </a>
          )}
        </div>

        <div class="mt-10">
          <h3 class="eyebrow">Zonas de servicio</h3>
          <p class="mt-2 text-sm text-[color:var(--color-suave)]">{AREAS_SERVED.join(' · ')}</p>
          <CostaMap class="mt-5 max-w-sm" />
        </div>
      </div>

      <!-- Formulario -->
      <div>
        <h2 class="text-2xl reveal">Escríbeme</h2>
        <p class="mt-2 text-sm text-[color:var(--color-suave)] reveal">Los campos marcados con * son obligatorios.</p>
        <div class="mt-5">
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
