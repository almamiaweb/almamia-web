---
import BaseLayout from '@templates/BaseLayout.astro';
import Breadcrumbs from '@molecules/Breadcrumbs.astro';
import AnswerBox from '@molecules/AnswerBox.astro';
import EventCard from '@molecules/EventCard.astro';
import CtaBanner from '@organisms/CtaBanner.astro';
import { route } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';
import { getEventos } from '@lib/content';

const lang = 'es' as const;
const t = useTranslations(lang);
const eventos = await getEventos(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.events'), url: route('pastEvents', lang) },
];
---

<BaseLayout
  lang={lang}
  pageKey="pastEvents"
  title="Eventos realizados · Experiencias de Alma Mía"
  description="Una selección de las experiencias gastronómicas privadas que Alma Mía diseña: cenas privadas, brunch de celebración, eventos temáticos y almuerzos en villa en Ibiza, Barcelona y Mallorca."
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">{t('nav.events')}</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Experiencias que han cobrado vida</h1>
    <div class="mt-6"><AnswerBox>Una muestra del tipo de experiencias gastronómicas privadas que diseña Alma Mía: cenas bajo las estrellas, brunch de celebración, eventos temáticos y almuerzos en villa, siempre a medida.</AnswerBox></div>
    <p class="mt-6 max-w-2xl text-[color:var(--color-suave)] reveal">
      Estas propuestas ilustran el tipo de experiencias que creo para cada cliente. Cada evento es único y se diseña desde cero según la ocasión.
    </p>
  </section>

  <section class="container-alma pb-12">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {eventos.map((e) => (
        <EventCard
          title={e.data.title}
          story={e.data.story}
          type={e.data.type}
          zona={e.data.zona}
          image={e.data.image}
          alt={e.data.imageAlt}
        />
      ))}
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>
