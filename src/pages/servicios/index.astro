---
import BaseLayout from '@templates/BaseLayout.astro';
import Breadcrumbs from '@molecules/Breadcrumbs.astro';
import AnswerBox from '@molecules/AnswerBox.astro';
import ServiceCard from '@molecules/ServiceCard.astro';
import CtaBanner from '@organisms/CtaBanner.astro';
import { route } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';

import imgBreakfast from '../../assets/placeholders/service-breakfast.jpg';
import imgLunch from '../../assets/placeholders/service-lunch.jpg';
import imgDinner from '../../assets/placeholders/service-dinner.jpg';
import imgEvents from '../../assets/placeholders/service-events.jpg';
import imgExperience from '../../assets/placeholders/service-experience.jpg';

const lang = 'es' as const;
const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.services'), url: route('services', lang) },
];

const services = [
  { key: 'breakfasts' as const, title: 'Desayunos y brunch saludable', blurb: 'Mañanas luminosas con producto fresco, opciones vegetales y repostería saludable.', image: imgBreakfast, alt: 'Mesa de brunch saludable con fruta y panes' },
  { key: 'lunches' as const, title: 'Comidas y almuerzos', blurb: 'Almuerzos mediterráneos servidos al ritmo del día.', image: imgLunch, alt: 'Plato de almuerzo mediterráneo emplatado con detalle' },
  { key: 'dinners' as const, title: 'Cenas privadas', blurb: 'Menús de varios pasos para compartir sin prisa.', image: imgDinner, alt: 'Mesa de cena privada con velas y lavanda' },
  { key: 'serviceEvents' as const, title: 'Eventos y celebraciones', blurb: 'Cumpleaños y experiencias temáticas diseñadas a medida.', image: imgEvents, alt: 'Montaje de evento festivo con decoración natural' },
  { key: 'experience' as const, title: 'Experiencia de chef privado', blurb: 'Servicio completo de principio a fin.', image: imgExperience, alt: 'Chef privada terminando un emplatado' },
];
---

<BaseLayout
  lang={lang}
  pageKey="services"
  title="Servicios de chef privada a domicilio | Alma Mía"
  description="Servicios de Alma Mía: desayunos y brunch saludable, comidas, cenas privadas, eventos y la experiencia completa de chef privado a domicilio en Ibiza, Barcelona y Mallorca."
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">{t('nav.services')}</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Servicios a tu medida</h1>
    <div class="mt-6"><AnswerBox>Alma Mía ofrece desayunos y brunch saludable, comidas, cenas privadas, eventos y la experiencia completa de chef privado a domicilio, con cocina mediterránea saludable y producto de temporada.</AnswerBox></div>
    <p class="mt-6 max-w-2xl text-lg text-[color:var(--color-suave)] reveal">
      Cada servicio se diseña a medida según la ocasión, el espacio y las personas. Elige el punto de partida; el resto lo construimos juntos.
    </p>
  </section>

  <section class="container-alma pb-12">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <ServiceCard
          title={s.title}
          blurb={s.blurb}
          href={route(s.key, lang)}
          image={s.image}
          alt={s.alt}
          cta={t('cta.readMore')}
        />
      ))}
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>
