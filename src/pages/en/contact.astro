---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import ContactForm from '../../components/ContactForm.astro';
import { route } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import { localBusinessSchema } from '../../lib/schema';
import { CONTACT, SOCIAL, PENDIENTE, whatsappLink, AREAS_SERVED } from '../../lib/site';

const lang = 'en' as const;
const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.contact'), url: route('contact', lang) },
];
const business = localBusinessSchema(lang, '/og/og-default.jpg');
const waMsg = 'Hi Jenn, I would like more information about Alma Mía.';
const phonePending = CONTACT.phone === PENDIENTE;
const emailPending = CONTACT.email === PENDIENTE;
---

<BaseLayout
  lang={lang}
  pageKey="contact"
  title="Contact · Book your experience with Alma Mía"
  description="Get in touch with Alma Mía to book your private chef experience in Ibiza, Barcelona or Mallorca. Message me on WhatsApp or through the form and I will prepare a tailored proposal."
  jsonLd={[business]}
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">{t('nav.contact')}</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Let's talk about your table</h1>
    <div class="mt-6"><AnswerBox>Tell me about the occasion, the date and the area, and I will prepare a tailored proposal. You can message me on WhatsApp for a quick reply or use the form; I will answer you personally.</AnswerBox></div>
  </section>

  <section class="container-alma pb-12">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.3fr]">
      <!-- Contact channels -->
      <div class="reveal">
        <h2 class="text-2xl">Direct contact</h2>
        <ul class="mt-5 flex flex-col gap-4 text-[color:var(--color-suave)]">
          <li>
            <span class="block text-sm font-semibold text-[color:var(--color-carbon)]">WhatsApp</span>
            <a href={whatsappLink(waMsg)} class="link-underline" data-cta="whatsapp">{t('cta.whatsapp')}</a>
          </li>
          <li>
            <span class="block text-sm font-semibold text-[color:var(--color-carbon)]">Email</span>
            {emailPending ? <span>{PENDIENTE}</span> : <a class="link-underline" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>}
          </li>
          <li>
            <span class="block text-sm font-semibold text-[color:var(--color-carbon)]">Phone</span>
            {phonePending ? <span>{PENDIENTE}</span> : <a class="link-underline" href={`tel:${CONTACT.phone.replace(/\s/g, '')}`}>{CONTACT.phone}</a>}
          </li>
          <li>
            <span class="block text-sm font-semibold text-[color:var(--color-carbon)]">Instagram</span>
            <a class="link-underline" href={SOCIAL.instagram} target="_blank" rel="me noopener">{SOCIAL.instagramHandle}</a>
          </li>
          <li>
            <span class="block text-sm font-semibold text-[color:var(--color-carbon)]">Service areas</span>
            <span>{AREAS_SERVED.join(' · ')}</span>
          </li>
        </ul>
      </div>

      <!-- Form -->
      <div>
        <h2 class="text-2xl reveal">Write to me</h2>
        <p class="mt-2 text-sm text-[color:var(--color-suave)] reveal">Fields marked with * are required.</p>
        <div class="mt-5">
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
