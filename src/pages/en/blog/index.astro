---
import { Image } from 'astro:assets';
import BaseLayout from '@templates/BaseLayout.astro';
import Breadcrumbs from '@molecules/Breadcrumbs.astro';
import AnswerBox from '@molecules/AnswerBox.astro';
import { route } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';
import { getBlogPosts } from '@lib/content';

const lang = 'en' as const;
const t = useTranslations(lang);
const posts = await getBlogPosts(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: 'Blog', url: route('blog', lang) },
];
const slugOf = (id: string) => id.replace(/-(es|en)$/, '');
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  lang={lang}
  pageKey="blog"
  title="Blog · Conscious cooking | Alma Mía"
  description="The Alma Mía blog: healthy Mediterranean cuisine, seasonal produce and the experience of a private chef who nourishes both body and soul."
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">Blog</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Conscious cooking</h1>
    <div class="mt-6"><AnswerBox>The Alma Mía blog brings together ideas on healthy Mediterranean cuisine, seasonal produce and the philosophy of a private chef who understands the table as an experience for both body and soul.</AnswerBox></div>
  </section>

  <section class="container-alma pb-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <article class="card-alma reveal overflow-hidden">
          <a href={`${route('blog', lang)}${slugOf(post.id)}/`} class="group block">
            {post.data.heroImage && (
              <div class="aspect-[16/10] overflow-hidden">
                <Image
                  src={post.data.heroImage}
                  alt={post.data.heroAlt}
                  widths={[400, 600, 800]}
                  sizes="(min-width: 1024px) 30vw, 90vw"
                  format="avif"
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <time class="text-xs uppercase tracking-wide text-[color:var(--color-suave)]" datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              <h2 class="mt-2 text-xl">{post.data.title}</h2>
              <p class="mt-2 text-sm text-[color:var(--color-suave)]">{post.data.description}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
