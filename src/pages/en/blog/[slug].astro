---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@templates/BaseLayout.astro';
import Breadcrumbs from '@molecules/Breadcrumbs.astro';
import CtaBanner from '@organisms/CtaBanner.astro';
import { route } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';
import { articleSchema } from '@lib/schema';
import { getBlogPosts } from '@lib/content';

const lang = 'en' as const;
const slugOf = (id: string) => id.replace(/-(es|en)$/, '');

export const getStaticPaths = (async () => {
  const posts = await getBlogPosts('en');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/-(es|en)$/, '') },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const url = `${route('blog', lang)}${slugOf(post.id)}/`;
const article = articleSchema({
  title: post.data.title,
  description: post.data.description,
  url,
  image: '/og/og-default.jpg',
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString(),
  author: post.data.author,
});

const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: 'Blog', url: route('blog', lang) },
  { name: post.data.title, url },
];
---

<BaseLayout
  lang={lang}
  pageKey="blog"
  title={`${post.data.title} | Alma Mía`}
  description={post.data.description}
  ogType="article"
  jsonLd={[article]}
>
  <Breadcrumbs items={crumbs} />

  <article class="container-narrow py-10 md:py-14">
    <header>
      <time class="text-sm uppercase tracking-wide text-[color:var(--color-suave)]" datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      <h1 class="mt-3 text-4xl md:text-5xl">{post.data.title}</h1>
      <p class="mt-4 text-lg text-[color:var(--color-suave)]">{post.data.description}</p>
    </header>

    {post.data.heroImage && (
      <Image
        src={post.data.heroImage}
        alt={post.data.heroAlt}
        widths={[600, 900, 1200]}
        sizes="(min-width: 768px) 46rem, 92vw"
        format="avif"
        loading="eager"
        fetchpriority="high"
        class="mt-8 aspect-[16/9] w-full rounded-[var(--radius-2xl)] object-cover shadow-[var(--shadow-soft)]"
      />
    )}

    <div class="prose-alma mt-10">
      <Content />
    </div>
  </article>

  <CtaBanner lang={lang} />
</BaseLayout>
