---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import EventCard from '../../components/EventCard.astro';
import Faq from '../../components/Faq.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { route } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import { localBusinessSchema } from '../../lib/schema';
import { SOCIAL } from '../../lib/site';
import { getEventos, getTestimonios } from '../../lib/content';

import heroImg from '../../assets/placeholders/hero.jpg';
import jennImg from '../../assets/placeholders/jenn-portrait.jpg';
import imgBreakfast from '../../assets/placeholders/service-breakfast.jpg';
import imgLunch from '../../assets/placeholders/service-lunch.jpg';
import imgDinner from '../../assets/placeholders/service-dinner.jpg';
import imgEvents from '../../assets/placeholders/service-events.jpg';
import imgExperience from '../../assets/placeholders/service-experience.jpg';

const lang = 'en' as const;
const t = useTranslations(lang);

const eventos = await getEventos(lang);
const testimonios = (await getTestimonios(lang)).filter((tt) => !tt.data.pending);


const services = [
  { key: 'breakfasts' as const, tab: 'Breakfast', title: 'Healthy breakfasts & brunch', blurb: 'Luminous mornings, fresh produce and wholesome pastries with thoughtful table styling.', image: imgBreakfast, alt: 'Healthy brunch table with fresh fruit and breads' },
  { key: 'lunches' as const, tab: 'Lunch', title: 'Lunches & midday meals', blurb: 'Mediterranean lunches served at the pace of the day, without ever compromising on eating well.', image: imgLunch, alt: 'Mediterranean lunch plate, carefully plated' },
  { key: 'dinners' as const, tab: 'Dinners', title: 'Private dinners', blurb: 'Multi-course menus made for lingering, with the cooking taken care of from start to finish.', image: imgDinner, alt: 'Private dinner table set with candles and lavender' },
  { key: 'serviceEvents' as const, tab: 'Events', title: 'Events & celebrations', blurb: 'Birthdays and themed experiences designed as one coherent whole.', image: imgEvents, alt: 'Festive event setting with natural décor' },
  { key: 'experience' as const, tab: 'Experience', title: 'Private chef experience', blurb: 'A complete service from start to finish: from menu design to the last lingering conversation.', image: imgExperience, alt: 'Private chef finishing a plate in a kitchen' },
];

const faq = [
  { q: 'What is a private chef at home?', a: 'It is a service in which the chef designs the menu, sources the produce, cooks in your space and handles the service and clean-up. You simply enjoy the experience with your guests.' },
  { q: 'Which areas does Alma Mía cover?', a: 'The base is in Ibiza, with coverage extending to Formentera, as well as Barcelona and Mallorca. For other locations, get in touch and I will check my availability to travel.' },
  { q: 'Are the menus adapted to allergies or special diets?', a: 'Yes. Every menu is tailored around allergies, intolerances and preferences, with plant-based options and wholesome desserts.' },
  { q: 'How do I book and how much does it cost?', a: 'You can book by writing to me on WhatsApp or through the contact form. The price depends on the menu, the number of guests and the location; I will put together a bespoke proposal for you.' },
];

const business = localBusinessSchema(lang, '/og/og-default.jpg');
---

<BaseLayout
  lang={lang}
  pageKey="home"
  title="Alma Mía · Private chef in Ibiza, Barcelona & Mallorca | Jenn Garrido"
  description="Private cooking that nourishes body and soul. Jenn Garrido Umaña, private chef based in Ibiza: private dinners, healthy brunch and at-home dining experiences in Ibiza, Barcelona and Mallorca."
  jsonLd={[business]}
  navOverlay
>
  <!-- Full-screen hero with single round CTA -->
  <section class="hero-full">
    <div class="hero-full__media">
      <Image
        src={heroImg}
        alt="Alma Mía private dinner table set with linen, candles and lavender"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        format="avif"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-full__veil"></div>
    <div class="container-alma relative flex flex-1 flex-col justify-end pb-12 pt-28 md:pb-16">
      <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="fx fx-1 font-mono text-sm uppercase tracking-[0.24em] text-[color:var(--color-crema)]/85">
            Private chef · Ibiza · Barcelona · Mallorca
          </p>
          <h1 class="fx fx-2 mt-5 display-fluid max-w-[13ch] text-[color:var(--color-crema)]">
            Private cooking that nourishes <em class="italic text-[color:var(--color-ocre)]">body and soul</em>
          </h1>
        </div>
        <div class="fx fx-3 shrink-0 self-start md:self-end">
          <a href={route('contact', lang)} data-cta="reserve" class="round-cta" aria-label="Book your experience — contact">
            <svg class="round-cta__ring" viewBox="0 0 100 100" aria-hidden="true">
              <defs><path id="cta-ring" d="M50,50 m-37,0 a37,37 0 1,1 74,0 a37,37 0 1,1 -74,0" /></defs>
              <text><textPath href="#cta-ring" startOffset="0">BOOK YOUR EXPERIENCE · ALMA MÍA · BOOK YOUR EXPERIENCE · ALMA MÍA · </textPath></text>
            </svg>
            <span class="round-cta__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Respuesta directa AEO -->
  <section class="container-alma py-10">
    <AnswerBox>
      Alma Mía is the private chef service of Jenn Garrido Umaña: healthy
      Mediterranean cooking and at-home dining experiences in Ibiza, Barcelona
      and Mallorca, with seasonal produce and intention in every dish.
    </AnswerBox>
  </section>

  <!-- Servicios -->
  <section class="container-alma py-12">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <hr class="rule-ocre reveal" />
        <h2 class="mt-4 text-3xl md:text-4xl reveal">A table for every occasion</h2>
      </div>
      <a href={route('services', lang)} class="text-sm font-semibold text-[color:var(--color-oliva-700)] link-underline reveal">{t('cta.viewServices')}</a>
    </div>

    <!-- Tab strip: each title slides the carousel to its card -->
    <div class="svc-tabs reveal" role="tablist" aria-label="Services">
      {services.map((s, i) => (
        <button type="button" class:list={['svc-tab', { 'is-active': i === 0 }]} data-svc-tab={i}>{s.tab}</button>
      ))}
    </div>

    <div class="mt-6 svc-carousel reveal" role="region" aria-label="Services — slide to see more" tabindex="0">
      {services.map((s) => (
        <div class="svc-slide">
          <ServiceCard
            title={s.title}
            blurb={s.blurb}
            href={route(s.key, lang)}
            image={s.image}
            alt={s.alt}
            cta={t('cta.discover')}
          />
        </div>
      ))}
    </div>
  </section>

  <script>
    function setupCarousel(carousel: Element, tabs: Element[] | null) {
      const slides = Array.from(carousel.querySelectorAll('.svc-slide'));
      if (slides.length < 1) return null;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let idx = 0;
      let timer: number | null = null;
      const go = (i: number) => {
        idx = (i + slides.length) % slides.length;
        slides[idx]?.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      };
      const stop = () => {
        if (timer !== null) { clearInterval(timer); timer = null; }
      };
      const start = () => {
        if (reduce || slides.length < 2) return;
        stop();
        timer = window.setInterval(() => go(idx + 1), 3800);
      };
      if (tabs) tabs.forEach((t, i) => t.addEventListener('click', () => { go(i); stop(); }));
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const i = slides.indexOf(e.target);
            if (i < 0) return;
            idx = i;
            slides.forEach((sl, j) => sl.classList.toggle('is-current', j === i));
            if (tabs) tabs.forEach((t, j) => t.classList.toggle('is-active', j === i));
          });
        },
        { root: carousel, threshold: 0.6 }
      );
      slides.forEach((s) => io.observe(s));
      carousel.addEventListener('pointerenter', stop);
      carousel.addEventListener('pointerleave', start);
      carousel.addEventListener('focusin', stop);
      carousel.addEventListener('touchstart', stop, { passive: true });
      start();
      return stop;
    }

    function initCarousels() {
      const w = window as unknown as { __almaStops?: (() => void)[] };
      w.__almaStops?.forEach((s) => s());
      const stops: (() => void)[] = [];
      document.querySelectorAll('.svc-carousel').forEach((c) => {
        const section = c.closest('section');
        const tabs = section ? Array.from(section.querySelectorAll('.svc-tab')) : [];
        const stop = setupCarousel(c, tabs.length ? tabs : null);
        if (stop) stops.push(stop);
      });
      w.__almaStops = stops;
    }
    if (document.readyState !== 'loading') initCarousels();
    else document.addEventListener('DOMContentLoaded', initCarousels);
  </script>

  <!-- Teaser Jenn -->
  <section class="container-alma py-12">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div class="reveal order-2 md:order-1">
        <hr class="rule-ocre" />
        <h2 class="mt-4 text-3xl md:text-4xl">Behind every dish, an intention</h2>
        <p class="mt-5 text-[color:var(--color-suave)] leading-relaxed">
          Jenn Garrido Umaña is a Colombian chef with a decade of craft spanning
          catering, events and restaurants across several countries. Trained at Mausi
          Sebess (Argentina) and specialised in healthy gastronomy and fine pastry
          in Barcelona, she created Alma Mía in 2024 to bring to every table a
          mindful Mediterranean cuisine, made with creativity, precision and care.
        </p>
        <a href={route('about', lang)} class="mt-6 inline-flex btn btn-secondary">{t('nav.about')}</a>
      </div>
      <div class="reveal order-1 md:order-2">
        <Image
          src={jennImg}
          alt="Portrait of Jenn Garrido Umaña, chef of Alma Mía"
          widths={[400, 600, 800]}
          sizes="(min-width: 768px) 45vw, 90vw"
          format="avif"
          loading="lazy"
          class="aspect-[4/5] w-full rounded-[var(--radius-2xl)] object-cover shadow-[var(--shadow-soft)]"
        />
      </div>
    </div>
  </section>

  <!-- Eventos destacados -->
  {eventos.length > 0 && (
    <section class="container-alma py-12">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <hr class="rule-ocre reveal" />
          <h2 class="mt-4 text-3xl md:text-4xl reveal">Experiences that have come to life</h2>
        </div>
        <a href={route('pastEvents', lang)} class="text-sm font-semibold text-[color:var(--color-oliva-700)] link-underline reveal">{t('cta.viewAll')}</a>
      </div>

      <div class="svc-tabs reveal" role="tablist" aria-label="Experiences">
        {eventos.map((e, i) => (
          <button type="button" class:list={['svc-tab', { 'is-active': i === 0 }]}>{e.data.type}</button>
        ))}
      </div>

      <div class="mt-6 svc-carousel event-carousel reveal" role="region" aria-label="Experiences — slide to see more" tabindex="0">
        {eventos.map((e) => (
          <div class="svc-slide">
            <EventCard
              title={e.data.title}
              story={e.data.story}
              type={e.data.type}
              zona={e.data.zona}
              image={e.data.image}
              alt={e.data.imageAlt}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Testimonios -->
  <section class="container-narrow py-12 text-center">
    <hr class="rule-ocre mx-auto reveal" />
    <h2 class="mt-4 text-3xl md:text-4xl reveal">What you feel at the table</h2>
    {testimonios.length > 0 ? (
      <div class="mt-8 grid gap-6">
        {testimonios.map((tt) => (
          <figure class="card-alma reveal p-7 text-left">
            <blockquote class="text-lg text-[color:var(--color-carbon)] font-serif">“{tt.data.text}”</blockquote>
            <figcaption class="mt-4 text-sm text-[color:var(--color-suave)]">— {tt.data.author}{tt.data.location ? `, ${tt.data.location}` : ''}</figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <p class="mt-6 text-[color:var(--color-suave)] reveal">
        We are gathering the first real reviews from clients. Very soon, right here.
        <br />
        <a href={route('testimonials', lang)} class="link-underline font-semibold text-[color:var(--color-oliva-700)]">{t('nav.testimonials')}</a>
      </p>
    )}
  </section>

  <!-- Instagram -->
  <section class="container-alma py-12">
    <div class="card-alma reveal flex flex-col items-center gap-4 bg-[color:var(--color-arena)] px-6 py-12 text-center">
      <hr class="rule-ocre" />
      <h2 class="text-3xl md:text-4xl">Cooking, the table and life on Instagram</h2>
      <p class="max-w-xl text-[color:var(--color-suave)]">
        I share the day-to-day of Alma Mía with a community of more than 6,000
        people. Inspiration, recipes and the table always set.
      </p>
      <a href={SOCIAL.instagram} target="_blank" rel="me noopener" class="btn btn-primary">
        Follow {SOCIAL.instagramHandle}
      </a>
    </div>
  </section>

  <Faq items={faq} title={t('common.faqTitle')} />

  <CtaBanner lang={lang} />
</BaseLayout>
