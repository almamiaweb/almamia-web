---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AnswerBox from '../components/AnswerBox.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { route } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import { getMenus } from '../lib/content';

const lang = 'es' as const;
const t = useTranslations(lang);
const menus = await getMenus(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.menus'), url: route('menus', lang) },
];
---

<BaseLayout
  lang={lang}
  pageKey="menus"
  title="Menús de ejemplo · Chef privada Alma Mía"
  description="Menús de ejemplo de Alma Mía: mediterráneo de temporada, brunch saludable y menú degustación de autor. Propuestas personalizables según temporada, alergias y preferencias."
>
  <Breadcrumbs items={crumbs} />

  <section class="container-alma py-10 md:py-14">
    <p class="eyebrow reveal">{t('nav.menus')}</p>
    <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">Menús de ejemplo</h1>
    <div class="mt-6"><AnswerBox>Estos son menús de ejemplo de Alma Mía. Cada propuesta se personaliza según la temporada, el número de comensales, las alergias y tus preferencias: son un punto de partida, no una carta cerrada.</AnswerBox></div>
  </section>

  <section class="container-alma pb-12">
    <div class="flex flex-col gap-10">
      {menus.map((m, i) => (
        <article class="card-alma reveal overflow-hidden lg:grid lg:grid-cols-2">
          {m.data.image && (
            <div class={`aspect-[4/3] lg:aspect-auto ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              <Image
                src={m.data.image}
                alt={m.data.imageAlt}
                widths={[500, 800, 1100]}
                sizes="(min-width: 1024px) 45vw, 92vw"
                format="avif"
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
          )}
          <div class="p-7 md:p-10">
            <h2 class="text-2xl md:text-3xl">{m.data.title}</h2>
            <p class="mt-3 text-[color:var(--color-suave)]">{m.data.description}</p>
            <div class="mt-6 flex flex-col gap-5">
              {m.data.courses.map((course) => (
                <div>
                  <h3 class="eyebrow">{course.section}</h3>
                  <ul class="mt-2 flex flex-col gap-1.5 text-[color:var(--color-carbon)]">
                    {course.items.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              ))}
            </div>
            {m.data.priceNote && (
              <p class="mt-6 text-sm text-[color:var(--color-suave)] italic">{m.data.priceNote}</p>
            )}
          </div>
        </article>
      ))}
    </div>

    <p class="mt-10 text-center text-[color:var(--color-suave)] reveal">
      ¿Buscas algo distinto? Diseño cada menú a medida. <a href={route('contact', lang)} class="link-underline font-semibold text-[color:var(--color-oliva-700)]">{t('cta.contact')}</a>
    </p>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>
