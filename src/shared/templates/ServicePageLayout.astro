---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '@templates/BaseLayout.astro';
import Breadcrumbs from '@molecules/Breadcrumbs.astro';
import AnswerBox from '@molecules/AnswerBox.astro';
import Faq from '@organisms/Faq.astro';
import CtaBanner from '@organisms/CtaBanner.astro';
import { route, type Locale, type RouteKey } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';
import { serviceSchema } from '@lib/schema';
import { whatsappLink, SITE } from '@lib/site';

interface Section {
  h2: string;
  body: string[];
}
interface Props {
  lang: Locale;
  pageKey: RouteKey;
  seoTitle: string;
  seoDescription: string;
  h1: string;
  answer: string;
  heroImage: ImageMetadata;
  heroAlt: string;
  intro: string;
  sections: Section[];
  includesTitle: string;
  includes: string[];
  faq: { q: string; a: string }[];
  serviceName: string;
  serviceDescription: string;
  related: { href: string; label: string }[];
}

const {
  lang,
  pageKey,
  seoTitle,
  seoDescription,
  h1,
  answer,
  heroImage,
  heroAlt,
  intro,
  sections,
  includesTitle,
  includes,
  faq,
  serviceName,
  serviceDescription,
  related,
} = Astro.props;

const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: t('nav.services'), url: route('services', lang) },
  { name: h1, url: route(pageKey, lang) },
];
const waMsg =
  lang === 'es'
    ? `Hola Jenn, me interesa el servicio: ${serviceName}.`
    : `Hi Jenn, I'm interested in the service: ${serviceName}.`;

const service = serviceSchema({
  name: serviceName,
  description: serviceDescription,
  url: route(pageKey, lang),
  image: SITE.url + '/og/og-default.jpg',
});
---

<BaseLayout
  lang={lang}
  pageKey={pageKey}
  title={seoTitle}
  description={seoDescription}
  jsonLd={[service]}
>
  <Breadcrumbs items={crumbs} />

  <!-- Hero -->
  <section class="container-alma grid items-center gap-10 py-10 md:py-16 lg:grid-cols-2">
    <div>
      <p class="eyebrow reveal">{t('nav.services')}</p>
      <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">{h1}</h1>
      <div class="mt-6">
        <AnswerBox>{answer}</AnswerBox>
      </div>
      <p class="mt-6 max-w-lg text-lg text-[color:var(--color-suave)] reveal">{intro}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row reveal">
        <a href={whatsappLink(waMsg)} class="btn btn-primary" data-cta="reserve">{t('cta.reserve')}</a>
        <a href={route('contact', lang)} class="btn btn-secondary">{t('cta.contact')}</a>
      </div>
    </div>
    <div class="reveal">
      <Image
        src={heroImage}
        alt={heroAlt}
        widths={[500, 800, 1100]}
        sizes="(min-width: 1024px) 45vw, 90vw"
        format="avif"
        loading="eager"
        fetchpriority="high"
        class="w-full rounded-[var(--radius-2xl)] object-cover shadow-[var(--shadow-lift)]"
      />
    </div>
  </section>

  <!-- Cuerpo -->
  <section class="container-narrow py-10">
    {sections.map((s) => (
      <div class="mb-10 reveal">
        <h2 class="text-2xl md:text-3xl">{s.h2}</h2>
        {s.body.map((p) => (
          <p class="mt-4 text-[color:var(--color-suave)] leading-relaxed">{p}</p>
        ))}
      </div>
    ))}

    <!-- Qué incluye -->
    <div class="card-alma reveal mt-4 p-7 md:p-9">
      <h2 class="text-2xl">{includesTitle}</h2>
      <ul class="mt-5 grid gap-3 sm:grid-cols-2">
        {includes.map((item) => (
          <li class="flex items-start gap-2.5 text-[color:var(--color-carbon)]">
            <svg class="mt-1 shrink-0 text-[color:var(--color-oliva)]" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <Faq items={faq} title={t('common.faqTitle')} />

  <!-- Enlazado interno -->
  {related.length > 0 && (
    <section class="container-alma py-8">
      <h2 class="text-2xl reveal">{t('common.relatedZones')}</h2>
      <ul class="mt-5 flex flex-wrap gap-3 reveal">
        {related.map((r) => (
          <li>
            <a href={r.href} class="inline-flex rounded-full border border-[color:var(--color-linea)] bg-[color:var(--color-superficie)] px-4 py-2 text-sm font-medium link-underline hover:bg-[color:var(--color-arena)]">{r.label}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <CtaBanner lang={lang} />
</BaseLayout>
