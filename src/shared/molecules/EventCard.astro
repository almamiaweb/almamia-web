---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Tag from '@atoms/Tag.astro';

interface Props {
  title: string;
  story: string;
  type: string;
  zona: string;
  image: ImageMetadata;
  alt: string;
}
const { title, story, type, zona, image, alt } = Astro.props;
---

<article class="card-alma reveal overflow-hidden">
  <div class="aspect-[4/3] overflow-hidden">
    <Image
      src={image}
      alt={alt}
      widths={[400, 600, 800]}
      sizes="(min-width: 768px) 45vw, 90vw"
      format="avif"
      loading="lazy"
      class="h-full w-full object-cover"
    />
  </div>
  <div class="p-6">
    <div class="flex flex-wrap items-center gap-2">
      <Tag variant="solid">{type}</Tag>
      <Tag variant="outline">{zona}</Tag>
    </div>
    <h3 class="mt-3 text-2xl">{title}</h3>
    <p class="mt-2 text-[color:var(--color-suave)]">{story}</p>
  </div>
</article>
