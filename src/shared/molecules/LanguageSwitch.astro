---
import { ROUTES, type Locale, type RouteKey } from '@i18n/routes';
import { useTranslations } from '@i18n/ui';

interface Props {
  lang: Locale;
  pageKey: RouteKey;
  class?: string;
}
const { lang, pageKey, class: className = '' } = Astro.props;
const other: Locale = lang === 'es' ? 'en' : 'es';
const href = ROUTES[pageKey][other];
const t = useTranslations(lang);
---

<a
  href={href}
  hreflang={other}
  lang={other}
  aria-label={t('lang.label')}
  class={`inline-flex items-center gap-1.5 text-sm font-semibold tracking-wide text-[color:var(--color-oliva-700)] link-underline ${className}`}
>
  <span aria-hidden="true">{other.toUpperCase()}</span>
  <span class="sr-only">{t('lang.switch')}</span>
</a>
