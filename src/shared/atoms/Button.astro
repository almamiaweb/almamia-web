---
/**
 * Átomo Button. Se renderiza como <a> si hay `href`, si no como <button>.
 * Variantes: primary (oliva oscuro), secondary (contorno), ghost (claro sobre fondo oscuro).
 */
interface Props {
  href?: string | undefined;
  variant?: 'primary' | 'secondary' | 'ghost';
  type?: 'button' | 'submit';
  class?: string | undefined;
  cta?: string | undefined;
  rel?: string | undefined;
  target?: string | undefined;
}
const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  cta,
  rel,
  target,
} = Astro.props;

const base = 'btn';
const variantClass =
  variant === 'primary'
    ? 'btn-primary'
    : variant === 'secondary'
      ? 'btn-secondary'
      : 'btn-ghost';
const cls = `${base} ${variantClass} ${className}`.trim();
const dataCta = cta ? { 'data-cta': cta } : {};
---

{
  href ? (
    <a href={href} class={cls} rel={rel} target={target} {...dataCta}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} {...dataCta}>
      <slot />
    </button>
  )
}
