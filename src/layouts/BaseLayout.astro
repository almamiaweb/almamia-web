---
import '../styles/global.css';
import { Font } from 'astro:assets';
import SpeedInsights from '@vercel/speed-insights/astro';

import SEO from '../components/SEO.astro';
import SiteNav from '../components/MinimalNav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import { useTranslations } from '../i18n/ui';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  pageKey: RouteKey;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Nav superpuesta y transparente sobre un hero a pantalla completa (home). */
  navOverlay?: boolean;
  /** Datos estructurados adicionales (LocalBusiness, Service, Article…). */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  lang,
  pageKey,
  ogImage,
  ogType,
  noindex,
  navOverlay = false,
  jsonLd = [],
} = Astro.props;

const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Fuentes: precarga la display (titulares = LCP frecuente) */}
    {/* Sin preload: display:swap pinta con Georgia al instante y no compite con la imagen LCP del hero */}
    <Font cssVariable="--ff-display" />
    <Font cssVariable="--ff-body" />

    <SEO
      title={title}
      description={description}
      lang={lang}
      pageKey={pageKey}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    {jsonLd.map((data) => <JsonLd data={data} />)}

    {/* Slots GTM/GA4/píxeles (desactivados salvo variables de entorno) */}
    <Analytics />
  </head>
  <body>
    <a href="#contenido" class="skip-link">{t('common.skipToContent')}</a>

    <SiteNav lang={lang} pageKey={pageKey} overlay={navOverlay} />

    <main id="contenido" class:list={[{ 'pt-[4.6rem]': !navOverlay }]}>
      <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppButton lang={lang} />

    <SpeedInsights />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        padding: 0.75rem 1.25rem;
        background: var(--color-oliva-700);
        color: #fff;
        border-radius: 0 0 var(--radius-md) 0;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>

    {/* Micro-animaciones de entrada al scroll (respetan reduced-motion) */}
    <script>
      function initReveals() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal');
        if (prefersReduced || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }
      if (document.readyState !== 'loading') initReveals();
      else document.addEventListener('DOMContentLoaded', initReveals);

      // Scroll vertical suave por JS para anclajes internos (#...) — desliza
      // aunque el navegador tenga reduce-motion (que fuerza el scroll nativo instantáneo).
      function smoothScrollY(targetY: number, duration: number) {
        const startY = window.scrollY;
        const change = targetY - startY;
        if (Math.abs(change) < 1) return;
        const t0 = performance.now();
        const ease = (t: number) => (t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2);
        const step = (now: number) => {
          const t = Math.min(1, (now - t0) / duration);
          window.scrollTo(0, startY + change * ease(t));
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
      document.addEventListener('click', (e) => {
        const t = e.target;
        const a = t instanceof Element ? t.closest('a[href^="#"]') : null;
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href || href === '#') return;
        const el = document.querySelector(href);
        if (!el) return;
        e.preventDefault();
        const y = el.getBoundingClientRect().top + window.scrollY - 72;
        smoothScrollY(y, 700);
        history.pushState(null, '', href);
      });
    </script>
  </body>
</html>
