---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AnswerBox from '../components/AnswerBox.astro';
import Faq from '../components/Faq.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { route, type Locale, type RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import { serviceSchema } from '../lib/schema';
import { whatsappLink, SITE } from '../lib/site';

interface Section {
  h2: string;
  body: string[];
}
interface Props {
  lang: Locale;
  pageKey: RouteKey;
  seoTitle: string;
  seoDescription: string;
  h1: string;
  answer: string;
  heroImage: ImageMetadata;
  heroAlt: string;
  intro: string;
  sections: Section[];
  servicesTitle: string;
  services: { href: string; label: string; desc: string }[];
  coverageTitle: string;
  coverage: string;
  faq: { q: string; a: string }[];
  zoneName: string;
  related: { href: string; label: string }[];
}

const {
  lang,
  pageKey,
  seoTitle,
  seoDescription,
  h1,
  answer,
  heroImage,
  heroAlt,
  intro,
  sections,
  servicesTitle,
  services,
  coverageTitle,
  coverage,
  faq,
  zoneName,
  related,
} = Astro.props;

const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: h1, url: route(pageKey, lang) },
];
const waMsg =
  lang === 'es'
    ? `Hola Jenn, busco un chef privado en ${zoneName}.`
    : `Hi Jenn, I'm looking for a private chef in ${zoneName}.`;

const service = serviceSchema({
  name: lang === 'es' ? `Chef privado en ${zoneName}` : `Private chef in ${zoneName}`,
  description: seoDescription,
  url: route(pageKey, lang),
  image: SITE.url + '/og/og-default.jpg',
});
---

<BaseLayout
  lang={lang}
  pageKey={pageKey}
  title={seoTitle}
  description={seoDescription}
  jsonLd={[service]}
>
  <Breadcrumbs items={crumbs} />

  <!-- Hero -->
  <section class="container-alma py-10 md:py-14">
    <div class="grid items-end gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow reveal">{t('nav.zones')}</p>
        <h1 class="mt-3 text-4xl reveal md:text-5xl lg:text-6xl">{h1}</h1>
        <div class="mt-6"><AnswerBox>{answer}</AnswerBox></div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row reveal">
          <a href={whatsappLink(waMsg)} class="btn btn-primary" data-cta="reserve">{t('cta.reserve')}</a>
          <a href={route('contact', lang)} class="btn btn-secondary">{t('cta.contact')}</a>
        </div>
      </div>
      <div class="reveal">
        <Image
          src={heroImage}
          alt={heroAlt}
          widths={[600, 900, 1400]}
          sizes="(min-width: 1024px) 50vw, 92vw"
          format="avif"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/3] w-full rounded-[var(--radius-2xl)] object-cover shadow-[var(--shadow-lift)]"
        />
      </div>
    </div>
  </section>

  <!-- Intro + cuerpo -->
  <section class="container-narrow py-8">
    <p class="text-lg text-[color:var(--color-suave)] leading-relaxed reveal">{intro}</p>
    {sections.map((s) => (
      <div class="mt-10 reveal">
        <h2 class="text-2xl md:text-3xl">{s.h2}</h2>
        {s.body.map((p) => (
          <p class="mt-4 text-[color:var(--color-suave)] leading-relaxed">{p}</p>
        ))}
      </div>
    ))}
  </section>

  <!-- Servicios en la zona -->
  <section class="container-alma py-8">
    <h2 class="text-2xl md:text-3xl reveal">{servicesTitle}</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <a href={s.href} class="card-alma reveal block p-6 transition-transform duration-300 hover:-translate-y-1">
          <h3 class="text-xl">{s.label}</h3>
          <p class="mt-2 text-sm text-[color:var(--color-suave)]">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Cobertura -->
  <section class="container-narrow py-8">
    <div class="card-alma reveal bg-[color:var(--color-arena)] p-7 md:p-9">
      <h2 class="text-2xl">{coverageTitle}</h2>
      <p class="mt-3 text-[color:var(--color-suave)] leading-relaxed">{coverage}</p>
    </div>
  </section>

  <Faq items={faq} title={t('common.faqTitle')} />

  {related.length > 0 && (
    <section class="container-alma py-8">
      <h2 class="text-2xl reveal">{t('common.relatedZones')}</h2>
      <ul class="mt-5 flex flex-wrap gap-3 reveal">
        {related.map((r) => (
          <li>
            <a href={r.href} class="inline-flex rounded-full border border-[color:var(--color-linea)] bg-[color:var(--color-superficie)] px-4 py-2 text-sm font-medium link-underline hover:bg-[color:var(--color-arena)]">{r.label}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <CtaBanner lang={lang} />
</BaseLayout>
