---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { route, type Locale, type RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Locale;
  pageKey: RouteKey;
  title: string;
  description: string;
  h1: string;
  lastUpdated: string;
}
const { lang, pageKey, title, description, h1, lastUpdated } = Astro.props;
const t = useTranslations(lang);
const crumbs = [
  { name: t('breadcrumb.home'), url: route('home', lang) },
  { name: h1, url: route(pageKey, lang) },
];
---

<BaseLayout lang={lang} pageKey={pageKey} title={title} description={description}>
  <Breadcrumbs items={crumbs} />
  <article class="container-narrow py-10 md:py-14">
    <h1 class="text-4xl md:text-5xl">{h1}</h1>
    <p class="mt-3 text-sm text-[color:var(--color-suave)]">
      {lang === 'es' ? 'Última actualización' : 'Last updated'}: {lastUpdated}
    </p>
    <div class="prose-alma mt-8">
      <slot />
    </div>
  </article>
</BaseLayout>
