# ─────────────────────────────────────────────────────────────
# Alma Mía — variables de entorno
# Copia este archivo a `.env` (local) y configúralas en Vercel (producción).
# Las variables PUBLIC_* se exponen al cliente; el resto son solo de servidor.
# ─────────────────────────────────────────────────────────────

# ── Formulario de contacto (Resend) ──
# API key de https://resend.com  → necesaria para que /api/contact envíe correos
RESEND_API_KEY=

# Dirección que RECIBE las solicitudes del formulario (email de Jenn)
CONTACT_TO_EMAIL=

# Remitente verificado en Resend (ej: "Alma Mía <hola@almamia.es>").
# Si se deja vacío, se usa el remitente de pruebas onboarding@resend.dev.
CONTACT_FROM_EMAIL=

# ── Verificación de buscadores (meta tags) ──
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# ── Analítica y Ads (OPCIONAL, desactivado por defecto) ──
# ⚠️ Al activar cualquiera de estos hace falta un banner de consentimiento
#    (Consent Mode v2) y añadir sus dominios a la CSP en astro.config.mjs.
# Google Tag Manager (recomendado: orquesta GA4, Ads y Meta)
PUBLIC_GTM_ID=
# Google Analytics 4 (alternativa directa a GTM)
PUBLIC_GA4_ID=
# Meta (Facebook/Instagram) Pixel
PUBLIC_META_PIXEL_ID=
# Google Ads (ID de conversiones)
PUBLIC_GOOGLE_ADS_ID=

# ── IndexNow (OPCIONAL) ──
# Clave para notificar cambios a Bing/Yandex vía IndexNow. Ver README → SEO.
INDEXNOW_KEY=
